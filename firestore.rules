rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }
    
    function isAdmin() {
      return hasRole('Admin');
    }
    
    function isOperator() {
      return hasRole('Operator');
    }
    
    function isBuyer() {
      return hasRole('Buyer');
    }

    // 1. Users collection
    match /users/{userId} {
      // Only Admins can see/manage all users
      // Users can read their own profile
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
      allow write: if isSignedIn() && isAdmin();
    }

    // 2. Master Data
    match /items/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /suppliers/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /buyers/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /expense_categories/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /workers/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /grade_profiles/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /size_profiles/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /grades/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /sizes/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // 3. Transactions
    match /receivings/{id} { allow read, write: if isSignedIn() && (isAdmin() || isOperator()); }
    match /sales/{id} { 
      allow read: if isSignedIn() && (isAdmin() || isOperator() || (isBuyer() && resource.data.buyerId == getUserData().linkedBuyerId));
      allow write: if isSignedIn() && (isAdmin() || isOperator()); 
    }
    match /processing/{id} { allow read, write: if isSignedIn() && (isAdmin() || isOperator()); }
    match /packing/{id} { allow read, write: if isSignedIn() && (isAdmin() || isOperator()); }
    match /expenses/{id} { allow read, write: if isSignedIn() && (isAdmin() || isOperator()); }
    match /dispatches/{docId} { 
      allow read: if isSignedIn() && (isAdmin() || isOperator() || (isBuyer() && resource.data.buyerId == getUserData().linkedBuyerId));
      allow write: if isSignedIn() && (isAdmin() || isOperator()); 
    }

    // 4. Stock & Movements
    match /stock/{id} {
      allow read: if isSignedIn(); 
      allow write: if isSignedIn() && (isAdmin() || isOperator());
    }
    match /stock_movements/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isOperator());
    }

    // 5. Buyer & Operational Support
    match /buyerAllocations/{id} {
      allow read: if isSignedIn() && (isAdmin() || isOperator() || (isBuyer() && resource.data.buyerId == getUserData().linkedBuyerId));
      allow write: if isSignedIn() && (isAdmin() || isOperator());
    }
    match /buyerCredits/{id} {
      allow read: if isSignedIn() && (isAdmin() || isOperator() || (isBuyer() && resource.data.buyerId == getUserData().linkedBuyerId));
      allow write: if isSignedIn() && (isAdmin() || isOperator());
    }
    match /adjustments/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isOperator());
    }
    match /payments/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isAdmin() || isOperator());
    }
    match /doc_numbers/{id} {
      allow read, write: if isSignedIn() && (isAdmin() || isOperator());
    }

    // 6. Reports & Audit
    match /reports/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /auditLog/{id} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if isSignedIn() && (isAdmin() || isOperator());
    }

    // Catch-all: Default to deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
