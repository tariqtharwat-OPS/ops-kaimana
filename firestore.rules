rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }
    
    function isAdmin() {
      return hasRole('Admin');
    }
    
    function isOperator() {
      return hasRole('Operator');
    }
    
    function isBuyer() {
      return hasRole('Buyer');
    }

    // 1. Users collection
    match /users/{userId} {
      // Only Admins can see/manage all users
      // Users can read their own profile
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
      allow write: if isSignedIn() && isAdmin();
    }

    // 2. Master Data (Products, Suppliers, Customers)
    match /master_products/{id} {
      allow read: if isSignedIn() && (isAdmin() || isOperator());
      allow write: if isSignedIn() && isAdmin();
    }
    match /master_suppliers/{id} {
      allow read: if isSignedIn() && (isAdmin() || isOperator());
      allow write: if isSignedIn() && isAdmin();
    }
    match /master_customers/{id} {
      allow read: if isSignedIn() && (isAdmin() || isOperator());
      allow write: if isSignedIn() && isAdmin();
    }

    // 3. Transactions (Receiving, Processing, Packing, Sales, Expenses)
    match /transactions_receiving/{id} {
      allow read, write: if isSignedIn() && (isAdmin() || isOperator());
    }
    match /transactions_processing/{id} {
      allow read, write: if isSignedIn() && (isAdmin() || isOperator());
    }
    match /transactions_packing/{id} {
      allow read, write: if isSignedIn() && (isAdmin() || isOperator());
    }
    match /transactions_sales/{id} {
      allow read, write: if isSignedIn() && (isAdmin() || isOperator());
    }
    match /transactions_expenses/{id} {
      allow read, write: if isSignedIn() && (isAdmin() || isOperator());
    }

    // 4. Stock
    match /stock/{id} {
      // Admin/Operator see all
      // Buyer sees only items assigned to them (if applicable)
      allow read: if isSignedIn() && (
        isAdmin() || 
        isOperator() || 
        (isBuyer() && resource.data.buyerId == getUserData().linkedBuyerId)
      );
      allow write: if isSignedIn() && (isAdmin() || isOperator());
    }

    // 5. Reports
    match /reports/{id} {
      allow read: if isSignedIn() && (isAdmin() || isOperator());
      allow write: if isSignedIn() && isAdmin();
    }

    // Catch-all: Default to deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
